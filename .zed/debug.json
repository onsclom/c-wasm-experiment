[
  {
    "label": "Debug test.c",
    "build": {
      "command": "cc",
      "args": [
        "test/test.c",
        "-Wall",
        "-Werror",
        "-g",
        "-O0",
        "-o",
        "test_runner",
      ],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/test_runner",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
]
